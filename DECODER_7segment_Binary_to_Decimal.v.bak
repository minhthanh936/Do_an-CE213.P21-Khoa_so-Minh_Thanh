module DECODER_7segment_Binary_to_Decimal(
input wire [3:0]IN,
output wire [6:0]OUT
);
assign OUT = (IN==4'b0000)?7'b1111110:((IN==4'b0001)?7'b0110000:((IN==4'b0010)?7'b1101101:((IN==4'b0011)?7'b1111001:
((IN==4'b0100)?7'b0110011:((IN==4'b0101)?7'b1011011:((IN==4'b0110)?7'b1011111:((IN==4'b0111)?7'b1110000:
((IN==4'b1000)?7'b1111111:((IN==4'b1001)?7'b1111011:7'b0000000)))))))));
endmodule